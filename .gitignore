node_modules/
dist/
coverage/
*.log
.DS_Store

# Environment / secrets — never commit
.env
.env.*
!.env.example

# Solana / Ballast keypairs — never commit
# Defense in depth: the canonical location is ~/.config/ballast/ (outside
# the repo), but match by name too in case anyone ever copies one in.
*keypair*.json
*-keypair.json
*.keypair
id.json
ballast-hedger.json
ballast-lp.json
ballast-oracle-authority.json
ballast-admin.json

# Ballast runtime config (only the *.example.json is committed)
config/ballast-config.json
config/*-local.json
# Per-deploy manifests + dump-market.ts JSON snapshots
config/ballast-*-deploy.json
config/*.dump.json

# pnpm store / caches
.pnpm-store/
.cache/

# Rust / matcher build artifacts (lockfile is committed for deterministic builds)
target/
**/*.rs.bk

# IDE
.vscode/
.idea/

# Per-user Claude Code settings (project-wide settings.json IS committed)
.claude/settings.local.json

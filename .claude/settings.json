{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(.env.local)",
      "Read(.env.production)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/*keypair*)",
      "Read(**/*-keypair.json)",
      "Read(~/.config/ballast/*.json)",
      "Read(~/.config/solana/id.json)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(.env.local)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Bash(cat .env*)",
      "Bash(cat */.env*)",
      "Bash(less .env*)",
      "Bash(more .env*)",
      "Bash(head .env*)",
      "Bash(tail .env*)",
      "Bash(grep -r * .env*)",
      "Bash(find * -name .env*)",
      "Bash(cat *secrets*)",
      "Bash(cat *keypair*)",
      "Bash(cat ~/.config/ballast/*)",
      "Bash(cat ~/.config/solana/*)",
      "Bash(less *keypair*)",
      "Bash(more *keypair*)",
      "Bash(head *keypair*)",
      "Bash(tail *keypair*)",
      "Bash(*--no-verify*)",
      "Bash(*--no-gpg-sign*)",
      "Bash(solana-keygen *)",
      "Bash(*mainnet*)",
      "Bash(*mainnet-beta*)"
    ],
    "disableBypassPermissionsMode": "disable"
  },
  "sandbox": {
    "enabled": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "registry.npmjs.org",
        "registry.yarnpkg.com",
        "*.npmjs.org",
        "api.devnet.solana.com",
        "hermes.pyth.network",
        "crates.io",
        "static.crates.io",
        "index.crates.io"
      ]
    }
  }
}
